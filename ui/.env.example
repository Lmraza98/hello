VITE_API_BASE_URL=
VITE_OLLAMA_URL=http://localhost:11434

# Tool-calling brain used for API interaction and intent routing.
# Route id is qwen3; model tag is configurable below.
VITE_TOOL_BRAIN=qwen3
VITE_PLANNER_BACKEND=qwen3
VITE_DECOMPOSE_CLASSIFIER_MODEL=gemma3:12b

# Optional explicit override for planner model tag.
# Example (Ollama): qwen3-coder-next:latest
VITE_OLLAMA_TOOL_BRAIN_MODEL=
VITE_OPENROUTER_TOOL_BRAIN_MODEL=
VITE_LLAMA_CPP_TOOL_BRAIN_MODEL_PATH=C:\llm\models\qwen2.5-coder-32b\Qwen2.5-Coder-32B-Instruct-Q4_K_M.gguf

# Optional per-model aliases.
VITE_OLLAMA_QWEN3_MODEL=qwen2.5:32b-instruct
VITE_OPENROUTER_QWEN3_MODEL=qwen/qwen3-coder-next
VITE_OLLAMA_DEVSTRAL_MODEL=devstral-small-2:latest
VITE_OPENROUTER_DEVSTRAL_MODEL=mistralai/devstral-small
VITE_OLLAMA_FUNCTIONGEMMA_MODEL=functiongemma:latest

# Qwen3-Coder-Next recommended sampling defaults (can override as needed).
VITE_QWEN3_TEMPERATURE=0.4
VITE_QWEN3_TOP_P=0.95
VITE_QWEN3_TOP_K=40
VITE_QWEN3_NUM_PREDICT=768

# Devstral sampling defaults for strict structured planning.
VITE_DEVSTRAL_TEMPERATURE=0.3
VITE_DEVSTRAL_TOP_P=0.9
VITE_DEVSTRAL_TOP_K=20
VITE_DEVSTRAL_NUM_PREDICT=768

VITE_OLLAMA_GEMMA_MODEL=gemma3:12b
VITE_OLLAMA_DEEPSEEK_MODEL=deepseek-r1:14b

# OpenAI route/fallback is disabled by default; set true only if you want it.
VITE_CHAT_ENABLE_OPENAI_ROUTE=false
VITE_CHAT_ALLOW_OPENAI_FALLBACK=false
VITE_OPENAI_CHAT_MODEL=gpt-4o-mini
VITE_OPENAI_PLANNER_MODEL=gpt-4o-mini

# Single-pass benchmark mode (bypasses planner/decomposition/tool execution).
VITE_CHAT_BENCHMARK_MODE=false
VITE_CHAT_BENCHMARK_MODEL=qwen2.5:32b-instruct
VITE_CHAT_BENCHMARK_NUM_PREDICT=256

# Planner model routing profile:
# - default: simple=gemma, complex/decomposition=gpt-4o-mini
# - premium: simple=gemma, complex/decomposition=gpt-4o
VITE_PLANNER_MODEL_PROFILE=default

# Optional explicit planner model-profile overrides.
# Allowed values: gemma | gpt-4o-mini | gpt-4o | claude-sonnet
VITE_PLANNER_SIMPLE_MODEL_PROFILE=gemma
VITE_PLANNER_COMPLEX_MODEL_PROFILE=gpt-4o-mini
VITE_PLANNER_DECOMPOSITION_MODEL_PROFILE=gpt-4o-mini

# Optional model IDs used by routed planner providers.
VITE_OPENAI_PLANNER_COMPLEX_MODEL=gpt-4o-mini
VITE_OPENAI_PLANNER_PREMIUM_MODEL=gpt-4o
VITE_OPENROUTER_PLANNER_COMPLEX_MODEL=anthropic/claude-3.5-sonnet
VITE_OPENROUTER_PLANNER_MODEL=

# Task decomposition (multi-step orchestration) timeout (ms).
VITE_TASK_DECOMPOSITION_TIMEOUT_MS=4500

# Browser workflow queue/concurrency controls (backend env vars shown here for reference).
# BROWSER_WORKFLOW_MAX_CONCURRENT_TASKS=3
# BROWSER_WORKFLOW_MAX_CONCURRENT_PER_WEBSITE=1

# Saved local llama.cpp launcher for Qwen2.5-Coder-32B (run from PowerShell).
# cd C:\llm\llama
# .\llama-cli.exe -m "C:\llm\models\qwen2.5-coder-32b\Qwen2.5-Coder-32B-Instruct-Q4_K_M.gguf" `
#   --n-gpu-layers 999 `
#   --tensor-split 0.35,0.65 `
#   --main-gpu 1 `
#   -c 8192 `
#   -n 16 `
#   -p "Reply with: OK"

# Hybrid challenge resolver (backend env vars shown here for reference).
# CHALLENGE_RESOLVER_ENABLED=true
# CHALLENGE_RESEARCH_MODE=false
# CHALLENGE_ALLOW_LIVE_HOSTS=false
# CHALLENGE_RESEARCH_ALLOWED_HOSTS=localhost,127.0.0.1,::1
# CHALLENGE_AI_ENABLED=false
# CHALLENGE_AI_MODEL=gpt-4o-mini
# CHALLENGE_AI_MAX_ROUNDS=2
# CHALLENGE_AI_MAX_ACTIONS=5
# CHALLENGE_HUMAN_FALLBACK_ENABLED=true
# CHALLENGE_HUMAN_WAIT_TIMEOUT_MS=180000
# CHALLENGE_HUMAN_POLL_INTERVAL_MS=1500
# CHALLENGE_RESOLVER_LOG_PATH=data/logs/challenge_resolver_events.jsonl
# CHALLENGE_RESOLVER_HANDOFF_DIR=data/logs/challenge_handoffs
# CHALLENGE_HUMAN_NOTIFY_WEBHOOK_URL=
