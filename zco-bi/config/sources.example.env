BI_BACKEND=sqlite
BI_SQLITE_PATH=../data/outreach.db

DATABASE_URL=postgres://postgres:postgres@localhost:5432/zco_bi
PORT=4010
AUTO_COLLECTOR=true
COLLECTOR_INTERVAL_MINUTES=15
PYTHON_BIN=python

# Existing local outreach SQLite (source-of-truth bootstrap)
OUTREACH_DB_ENABLED=true
OUTREACH_DB_PATH=../data/outreach.db
OUTREACH_DB_TARGET_LIMIT=2000

# Optional source API keys
SALESNAV_COOKIE=
CRUNCHBASE_API_KEY=
CLEARBIT_API_KEY=
APOLLO_API_KEY=
GOOGLE_NEWS_API_KEY=

# SalesNav source
SALESNAV_ENABLED=true
SALESNAV_COLLECT_URL=http://localhost:8000/api/companies/collect
SALESNAV_QUERIES=healthcare companies in united states|fintech companies in united states
SALESNAV_MAX_COMPANIES=50
SALESNAV_REQUEST_TIMEOUT_MS=90000
SALESNAV_SAFE_MODE=true
SALESNAV_MIN_INTERVAL_MINUTES=120
SALESNAV_MAX_QUERIES_PER_CYCLE=1
SALESNAV_DAILY_MAX_REQUESTS=12
SALESNAV_INTER_QUERY_DELAY_MS=5000
BI_SOURCE_COMPANY_POOL_LIMIT=200

# Crunchbase source
CRUNCHBASE_ENABLED=false
CRUNCHBASE_ORG_URL_TEMPLATE=https://api.crunchbase.com/api/v4/entities/organizations/{org}
CRUNCHBASE_ORGS=
CRUNCHBASE_MAX_COMPANIES_PER_CYCLE=5

# App Store source
APPSTORE_ENABLED=true
APPSTORE_MAX_COMPANIES_PER_CYCLE=5
APPSTORE_MIN_NAME_OVERLAP_RATIO=0.5

# Play Store source
PLAYSTORE_ENABLED=false
PLAYSTORE_MAX_COMPANIES_PER_CYCLE=5

# Company website crawl source
WEBSITE_SIGNALS_ENABLED=false
WEBSITE_SIGNALS_MAX_COMPANIES_PER_CYCLE=5

# Job postings source (optional local collector endpoint)
JOB_POSTINGS_ENABLED=false
JOB_POSTINGS_COLLECT_URL=
JOB_POSTINGS_MAX_COMPANIES_PER_CYCLE=5
JOB_POSTINGS_MAX_RESULTS=20
JOB_POSTINGS_TIMEOUT_MS=60000

# Google News source
GOOGLE_NEWS_ENABLED=true
GOOGLE_NEWS_MAX_COMPANIES_PER_CYCLE=5
